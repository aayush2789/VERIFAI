# VERIFAI Environment Configuration Example
# Copy this file to .env and fill in your actual values

# ============================================================================
# API KEYS
# ============================================================================

# NCBI/PubMed Configuration
# Required: Your email address (NCBI policy requirement)
NCBI_EMAIL=your.email@example.com

# Optional: NCBI API key (increases rate limit from 3 to 10 requests/second)
# Get your key at: https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=your_ncbi_api_key_here

# Semantic Scholar API Key
# Optional but recommended for better rate limits
# Get your key at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_key_here

# HuggingFace Token
# Required for accessing gated models (MedGemma, MedSigLIP)
# Get your token at: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=your hugging face token 

# ============================================================================
# OPTIMIZATION FLAGS (Recommended Settings)
# ============================================================================

# Enable fast literature mode (parallel search, no ReAct loop)
# Recommended: True for 75-85% speed improvement
USE_FAST_LITERATURE_MODE=True

# Enable literature query caching
# Recommended: True for instant responses on repeated queries
USE_LITERATURE_CACHE=True

# Enable parallel agent execution
# Recommended: True for better throughput
USE_PARALLEL_AGENTS=True

# Preload models at startup (uses more RAM but faster inference)
# Set to True if you have >16GB RAM and want maximum speed
PRELOAD_MODELS=False

# ============================================================================
# MOCK MODE (Development)
# ============================================================================

# Set to True to run without downloading large models (~50GB)
# Set to False for production with real models
MOCK_MODELS=True

# ============================================================================
# UNCERTAINTY THRESHOLDS (Advanced)
# ============================================================================

# Adjust these to control when different agents are invoked
# Higher values = stricter criteria = fewer agent calls = faster
THRESHOLD_HISTORIAN=0.30
THRESHOLD_LITERATURE=0.40
THRESHOLD_CHIEF=0.50

# Maximum routing steps (prevents infinite loops)
MAX_ROUTING_STEPS=5

# ============================================================================
# FHIR CONFIGURATION (Optional)
# ============================================================================

# FHIR server base URL
FHIR_BASE_URL=https://fhir.mimic-iv-demo.physionet.org/fhir

# FHIR authentication token (if required by your server)
# FHIR_AUTH_TOKEN=your_fhir_token_here

# ============================================================================
# SUPABASE CONFIGURATION (Cloud Database)
# ============================================================================

# Supabase project URL (get from your Supabase dashboard)
# Format: https://xxxxxxxxxxxxx.supabase.co
SUPABASE_URL=your_supabase_project_url_here

# Supabase anon/public API key (get from your Supabase dashboard)
# This is safe to use in client-side code
SUPABASE_KEY=your_supabase_anon_key_here

# Optional: Supabase service role key (for admin operations)
# WARNING: Keep this secret! Do NOT expose in client-side code
# SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Database mode selection
# Set to 'supabase' for cloud database (recommended for production)
# Set to 'sqlite' for local database (development/testing only)
DATABASE_MODE=supabase

# ============================================================================
# ADVANCED: MULTIPLE API KEYS
# ============================================================================

# If you have multiple API keys with different rate limits,
# configure them in config.py instead:
#
# NCBI_API_KEYS = [
#     {"key": "fast_key_10_req_per_sec", "requests_per_second": 10, "max_burst": 10},
#     {"key": "slow_key_1_req_per_sec", "requests_per_second": 1, "max_burst": 5}
# ]
#
# The rate limiter will automatically use the fastest available key!
